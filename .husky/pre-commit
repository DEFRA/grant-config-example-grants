branch="$(git symbolic-ref --short HEAD)"
currentUser="$(git config user.name)"

if [ "$currentUser" != "github-actions[bot]" ]; then
    if [ "$branch" = "main" ]; then
      echo "❌ Please don't commit to main, make sure you are on a specific branch!"
      exit 1
    fi

    compgen -G ".changeset/*-*-*.md" || (echo ❌ Make sure you have added a changeset file for this commit! && exit 1)
fi